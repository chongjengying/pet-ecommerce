# Supabase – copy to .env.local and set from Dashboard → Project Settings → API
# Use Project URL and either "anon" (JWT) or "Publishable" key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
NEXT_PUBLIC_SUPABASE_PRODUCT_BUCKET=pet_commerce
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Customer custom auth JWT secret (use a long random string)
CUSTOMER_JWT_SECRET=change-me-to-a-long-random-string

# Admin login (/admin) — use a strong random password and a long random secret (e.g. openssl rand -hex 32)
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
