# Supabase - copy to .env.local and set from Dashboard -> Project Settings -> API
# Use Project URL and either "anon" (JWT) or "Publishable" key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
NEXT_PUBLIC_SUPABASE_PRODUCT_BUCKET=pet_commerce
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: shipping rows table name if not `user_addresses` (e.g. your existing `addresses` table)
# SUPABASE_ADDRESSES_TABLE=addresses

# Customer custom auth JWT secret (use a long random string)
CUSTOMER_JWT_SECRET=change-me-to-a-long-random-string

# Admin login (/admin) uses users.role = 'admin' credentials and this session secret
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Checkout email notifications (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=orders@your-domain.com
CHECKOUT_EMAIL_FROM_NAME=Pawluxe
# Optional hardening for POST /api/notifications/checkout-email
EMAIL_NOTIFICATION_SECRET=change-me-to-another-long-random-string
